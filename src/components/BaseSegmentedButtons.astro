---

---

<div class="buttons">
	<slot />
</div>

<style>
	.buttons {
		display: flex;
		border: var(--border);
		border-radius: var(--border-radius-pill);
		background: var(--c-surface);
		flex-direction: row;
		flex-wrap: nowrap;
		justify-content: space-between;
		align-items: flex-start;
		align-content: stretch;
		overflow: hidden;
		@media screen and (width <= 30rem) {
			width: 100%;

			/* Pill radius on a tall vertical stack balloons into huge dome corners;
			   drop to the normal radius once the buttons stack. */
			border-radius: var(--border-radius);
			flex-direction: column;
		}
		> :global(*) {
			margin: 0;
			padding: var(--xs) var(--m);
			border: none;
			border-right: 1px solid var(--c-surface-accent);
			background: transparent;
			color: var(--c-font);
			font-size: var(--font-m);
			font-weight: 500;
			line-height: 1.2;
			text-align: center;
			text-decoration: none;
			transition: var(--transition);
			&:hover {
				border-right: 1px transparent solid;
				background: var(--c-font);
				color: var(--c-light);
				cursor: pointer;
			}
			&:last-child {
				border-right: none;
			}
			@media screen and (width <= 30rem) {
				width: 100%;
				border-right: none;
				&:not(:last-child) {
					border-bottom: 1px solid var(--c-surface-accent);
				}
			}
		}
	}
</style>
