---

<div class="buttons">
	<slot />
</div>

<style>
	.buttons {
		display: flex;
		border: var(--border);
		border-radius: var(--border-radius-pill);
		background: var(--c-surface);
		flex-direction: row;
		flex-wrap: nowrap;
		justify-content: space-between;
		align-items: flex-start;
		align-content: stretch;
		overflow: hidden;

		/* On mobile the label and buttons stack, so the row stretches to full width
		   instead of collapsing into a column. */
		@media screen and (width <= 48rem) {
			width: 100%;
		}
		> :global(*) {
			margin: 0;
			padding: var(--xs) var(--m);
			min-width: 0;
			border: none;
			border-right: 1px solid var(--c-surface-accent);
			background: transparent;
			color: var(--c-font);
			font-size: var(--font-m);
			font-weight: 500;
			line-height: 1.2;
			text-align: center;
			text-decoration: none;
			transition: var(--transition);
			&:hover {
				border-right: 1px transparent solid;
				background: var(--c-font);
				color: var(--c-light);
				cursor: pointer;
			}
			&:last-child {
				border-right: none;
			}

			/* Each segment stretches evenly to fill the full-width row on mobile. */
			@media screen and (width <= 48rem) {
				flex: 1;
			}

			/* Tighter padding/size on phones so multi-segment rows (e.g. socials) fit. */
			@media screen and (width <= 32rem) {
				padding-inline: var(--xs);
				font-size: var(--font-s);
			}
		}
	}
</style>
