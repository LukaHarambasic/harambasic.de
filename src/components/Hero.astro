---
interface Props {
	title: string;
	description: string;
}

const { title, description } = Astro.props;
---

<section class="hero golden-ratio">
	<h1 class="title">{title}</h1>
	<p class="description">{description}</p>
	<slot />
</section>

<style>
	.hero {
		display: flex;
		flex-direction: column;
		gap: var(--m);
		.title {
			margin: 0;
			color: var(--c-font);
			font-family: var(--font-family-serif);
			font-size: var(--fs-display);
			font-weight: 500;
			line-height: 1.04;
			letter-spacing: var(--tracking-display);
			hyphens: none;
			&::after {
				display: block;
				margin-block-start: var(--m);
				width: var(--deco-bar-width);
				height: var(--deco-bar-height);
				border-radius: var(--deco-bar-radius);
				background: var(--deco-bar-color);
				content: '';
			}
		}
		.description {
			margin: 0;
			max-width: 65ch;
			color: var(--c-font-accent-dark);
			font-size: var(--font-m);
			line-height: 1.5;
		}
	}
</style>
