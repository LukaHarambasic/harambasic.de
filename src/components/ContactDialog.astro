---
import { Icon } from 'astro-icon/components';
import BaseSegmentedButtons from './BaseSegmentedButtons.astro';
---

<dialog id="contact-dialog">
	<div class="content">
		<div class="contact-modal">
			<h2 class="header">Get in touch</h2>
			<p class="intro">
				Drop a line. Talk AI, automation, product direction, or just say hi. Pick whatever channel
				works.
			</p>
			<dl class="contact">
				<div class="group">
					<dt class="meta">
						<strong>E-Mail</strong>
						<small>luka@harambasic.de</small>
					</dt>
					<dd>
						<BaseSegmentedButtons>
							<a href="mailto:luka@harambasic.de">Write</a>
							<button class="button" type="button" data-clipboard="luka@harambasic.de">Copy</button>
						</BaseSegmentedButtons>
					</dd>
				</div>
				<div class="group">
					<dt class="meta">
						<strong>Socials</strong>
						<small>Get in touch!</small>
					</dt>
					<dd>
						<BaseSegmentedButtons>
							<a
								href="https://signal.me/#eu/nEQUfJVmtAbHirhDccRIQMkqWOiIiq2/7VROG9o/YrlzrC9ejHlCxYgFg1HMGx2B"
								>Signal</a
							>
							<a href="https://www.linkedin.com/in/harambasic/">LinkedIn</a>
							<a href="https://bsky.app/profile/harambasic.de">BlueSky</a>
							<a href="https://github.com/LukaHarambasic">GitHub</a>
						</BaseSegmentedButtons>
					</dd>
				</div>
				<div class="group">
					<dt class="meta">
						<strong>Book a time</strong>
						<small>Wanna talk?</small>
					</dt>
					<dd>
						<BaseSegmentedButtons>
							<a href="https://cal.com/luhara/1">Book</a>
						</BaseSegmentedButtons>
					</dd>
				</div>
			</dl>
		</div>
		<form method="dialog">
			<button class="close" aria-label="Close"><Icon name="ph:x-circle-bold" /></button>
		</form>
	</div>
</dialog>

<style>
	dialog {
		margin: auto;
		width: min(54em, calc(100vw - 2 * var(--l)));
		border: var(--border);
		border-radius: var(--border-radius);
		background: var(--c-light);
		color: var(--c-font);
		&::backdrop {
			background: var(--c-backdrop);
		}
		.content {
			padding: var(--xl);
			@media screen and (width <= 64rem) {
				padding: var(--l);
			}
			.close {
				--icon-size: 1.5rem;
				--icon-padding: var(--xs);

				display: flex;
				position: absolute;
				inset-block-start: var(--l);
				inset-inline-end: var(--l);
				z-index: 3000;
				padding: var(--icon-padding);
				size: calc(var(--icon-size) + var(--icon-padding) * 2);
				border: none;
				border-radius: 50%;
				background: transparent;
				flex-shrink: 0;
				justify-content: center;
				align-items: center;
				color: var(--c-font);
				font-size: var(--icon-size);
				transition: var(--transition);
				cursor: pointer;
				:global(svg) {
					width: var(--icon-size);
					height: var(--icon-size);
					transition: var(--transition);
				}
				&:hover {
					:global(svg) {
						transform: scale(1.2);
					}
				}
				@media screen and (width <= 48rem) {
					inset-block-start: var(--m);
					inset-inline-end: var(--m);
				}
			}
		}
		&[open] {
			animation: zoom 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
		}
		&[open]::backdrop {
			animation: fade 0.2s ease-out;
		}
	}
	@keyframes zoom {
		from {
			transform: scale(0.95);
		}
		to {
			transform: scale(1);
		}
	}
	@keyframes fade {
		from {
			opacity: 0;
		}
		to {
			opacity: 1;
		}
	}

	.contact-modal {
		.header {
			margin: 0 0 var(--m) 0;
			font-family: var(--font-family-serif);
			font-size: var(--fs-h2);
			font-weight: 500;
			line-height: 1.2;
			letter-spacing: var(--tracking-heading);
		}
		.intro {
			margin: 0 0 var(--m) 0;
			font-size: var(--font-m);
			line-height: 1.4;
		}
		.contact {
			display: flex;
			margin: 0;
			width: 100%;
			flex-direction: column;
			.group {
				display: flex;
				padding: var(--l);
				border-block-end: 1px solid var(--c-border);
				flex-direction: row;
				justify-content: space-between;
				align-items: flex-start;
				@media screen and (width <= 48rem) {
					flex-direction: column;
					gap: var(--l);
				}
				dd {
					margin: 0;
				}
				.meta {
					display: flex;
					flex-direction: column;
					strong {
						margin-block-end: var(--xs);
						font-size: var(--font-m);
						font-weight: 600;
						line-height: 1.2;
					}
					small {
						font-size: var(--font-s);
					}
				}
			}
		}
	}
</style>
