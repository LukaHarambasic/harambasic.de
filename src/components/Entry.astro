---
import { Icon } from 'astro-icon/components';

/**
 * The one list-item anatomy, in three presets:
 * - row: text-forward, sits in a rule-separated EntryList (posts, feed, uses archive)
 * - card: filled surface with a logo+title header (work, uses essentials/hardware)
 * - gallery: media-forward, image on top (projects)
 *
 * Two states everywhere: hover (tint fill + arrow nudge) and featured (inverted
 * plum surface = "the live/pinned/latest one").
 */
interface Props {
	variant?: 'row' | 'card' | 'gallery';
	href: string;
	title: string;
	titleTag?: 'h2' | 'h3' | 'strong';
	eyebrow?: string;
	meta?: string;
	metaDatetime?: string;
	excerpt?: string;
	external?: boolean;
	featured?: boolean;
	condensed?: boolean;
	class?: string;
	[key: string]: unknown;
}

const {
	variant = 'row',
	href,
	title,
	titleTag = 'h2',
	eyebrow,
	meta,
	metaDatetime,
	excerpt,
	external = false,
	featured = false,
	condensed = false,
	class: className,
	...rest
} = Astro.props;

const TitleTag = titleTag;
const hasMedia = Astro.slots.has('media');
const rel = external ? 'external' : undefined;
---

<a
	href={href}
	class:list={['entry', variant, className, { featured, condensed }]}
	rel={rel}
	{...rest}
>
	{
		variant === 'card' ? (
			<Fragment>
				<div class="head">
					{hasMedia && (
						<div class="media">
							<slot name="media" />
						</div>
					)}
					<div class="heading">
						{eyebrow && <span class="eyebrow">{eyebrow}</span>}
						<TitleTag class="title">{title}</TitleTag>
						{meta &&
							(metaDatetime ? (
								<time class="meta" datetime={metaDatetime}>
									{meta}
								</time>
							) : (
								<span class="meta">{meta}</span>
							))}
						{excerpt && <p class="excerpt">{excerpt}</p>}
					</div>
				</div>
				<slot />
			</Fragment>
		) : (
			<Fragment>
				{hasMedia && (
					<div class="media">
						<slot name="media" />
					</div>
				)}
				<div class="body">
					{eyebrow && <span class="eyebrow">{eyebrow}</span>}
					<TitleTag class="title">{title}</TitleTag>
					{meta &&
						(metaDatetime ? (
							<time class="meta" datetime={metaDatetime}>
								{meta}
							</time>
						) : (
							<span class="meta">{meta}</span>
						))}
					{excerpt && <p class="excerpt">{excerpt}</p>}
					<slot />
				</div>
			</Fragment>
		)
	}
	<span class="affordance" aria-hidden="true">
		<Icon name={external ? 'ph:arrow-square-out-bold' : 'ph:arrow-up-right-bold'} />
	</span>
</a>

<style>
	.entry {
		display: flex;
		position: relative;
		background: var(--entry-bg, transparent);
		flex-direction: column;
		gap: var(--xs);
		color: inherit;
		text-decoration: none;
		transition: var(--transition);

		/* Inherited theming hooks so slotted content (e.g. WorkCard) can follow
		   the featured/inverted state without reaching into Entry internals. */
		--entry-muted: var(--c-font-accent-dark);
		--entry-line: var(--c-line);

		&:hover {
			background: color-mix(in srgb, var(--c-surface-accent) 40%, var(--entry-bg, transparent));
			.affordance {
				color: currentcolor;
				transform: translateY(-2px) translateX(2px);
			}
		}

		.affordance {
			display: flex;
			position: absolute;
			inset-block-start: var(--l);
			inset-inline-end: var(--l);
			width: 1.5rem;
			height: 1.5rem;
			flex-shrink: 0;
			justify-content: center;
			align-items: center;
			color: var(--c-font-accent-super-light);
			transition: var(--transition);
			pointer-events: none;
			:global(svg) {
				width: 1rem;
				height: 1rem;
			}
		}

		.body,
		.heading {
			display: flex;
			min-width: 0;
			flex: 1;
			flex-direction: column;
			gap: var(--xs);
		}
		.eyebrow {
			color: var(--entry-muted);
			font-size: var(--font-xs);
			font-weight: 600;
			letter-spacing: var(--tracking-eyebrow);
			text-transform: uppercase;
		}
		.title {
			margin: 0;
			font-family: var(--font-family-serif);
			font-size: var(--fs-h3);
			font-weight: 500;
			line-height: 1.2;
			letter-spacing: var(--tracking-heading);
		}
		.meta {
			color: var(--entry-muted);
			font-size: var(--font-s);
			line-height: 1.5;
		}
		.excerpt {
			margin: 0;
			color: var(--entry-muted);
			font-size: var(--font-m);
			line-height: 1.5;
		}

		/* Preset: row - text-forward, media as a small thumb on the left */
		&.row {
			padding: var(--l);
			padding-inline-end: calc(var(--l) + 1.5rem + var(--xs));
			border-radius: var(--border-radius);
			flex-direction: row;
			align-items: flex-start;
			gap: var(--m);
			@container entry-list (width <= 34rem) {
				flex-direction: column;
			}
			.media {
				display: flex;
				width: 3rem;
				border-radius: var(--border-radius-small);
				flex-shrink: 0;
				justify-content: center;
				align-items: flex-start;
				overflow: hidden;
				:global(img),
				:global(picture) {
					display: block;
					width: 100%;
					height: auto;
					vertical-align: top;
				}
			}
		}

		/* Preset: card - filled surface, logo+title header, structured body */
		&.card {
			padding: var(--l);
			border: 1px solid var(--c-surface-accent);
			border-radius: var(--border-radius);
			gap: var(--m);

			--entry-bg: var(--c-surface);
			.head {
				display: flex;
				padding-inline-end: calc(1.5rem + var(--xs));
				justify-content: flex-start;
				align-items: flex-start;
				gap: var(--m);

				/* Title + subtitle only (no excerpt): tighten the pair and center
				   it against the media box so the header aligns visually. */
				&:has(.meta):not(:has(.excerpt)) {
					align-items: center;
					.heading {
						gap: var(--xxs);
					}
				}
			}
			.media {
				display: flex;
				padding: var(--xxs);
				width: 3rem;
				height: 3rem;
				border-radius: var(--border-radius-small);
				background: var(--c-font-accent-super-light);
				flex-shrink: 0;
				justify-content: center;
				align-items: center;
				overflow: hidden;
				box-sizing: border-box;
				:global(img),
				:global(picture) {
					display: block;
					width: 100%;
					height: 100%;

					/* Concentric with the media box: outer radius minus the inner padding. */
					border-radius: calc(var(--border-radius-small) - var(--xxs));
					object-fit: contain;
				}
			}
		}

		/* Preset: gallery - media-forward, image on top */
		&.gallery {
			border: 1px solid var(--c-surface-accent);
			border-radius: var(--border-radius);
			overflow: hidden;

			--entry-bg: var(--c-surface);
			.media {
				width: 100%;
				aspect-ratio: 16 / 10;
				overflow: hidden;
				:global(picture),
				:global(img) {
					display: block;
					width: 100%;
					height: 100%;
					object-fit: cover;
					object-position: top;
					filter: grayscale(1);
					transition: filter var(--transition-time) var(--transition-ease);
				}
			}
			&:hover .media :global(img) {
				filter: grayscale(0);
			}
			.body {
				padding: var(--l);
			}
			.affordance {
				inset-block-start: var(--m);
				inset-inline-end: var(--m);
			}
		}

		/* Modifier: condensed - tighter padding and smaller type for dense lists */
		&.condensed {
			padding: var(--s) var(--m);
			padding-inline-end: calc(var(--m) + 1.5rem);
			gap: var(--xs);
			.affordance {
				inset-block-start: var(--s);
				inset-inline-end: var(--s);
			}
			.title {
				font-size: var(--font-m);
			}
			.excerpt {
				font-size: var(--font-s);
			}
		}

		/* State: featured - the inverted plum surface, the one site-wide signal
		   for "this is the live/pinned/latest one". */
		&.featured {
			border-color: var(--c-inverted-line);

			--entry-bg: var(--c-inverted);
			--entry-muted: var(--c-inverted-text-muted);
			--entry-line: var(--c-inverted-line);

			color: var(--c-inverted-text);
			&:hover {
				background: var(--c-inverted);
			}
			.affordance {
				color: var(--c-inverted-text-muted);
			}
			&:hover .affordance {
				color: var(--c-inverted-text);
			}
			&.card .media {
				background: var(--c-inverted-line);
			}
		}
	}
</style>
