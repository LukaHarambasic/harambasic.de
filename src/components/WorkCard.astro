---
import { Picture } from 'astro:assets';
import Entry from './Entry.astro';
import type { WorkEntry } from '$lib/types/workEntry';
import { getWorkImage, isSvgImage, IMAGE_WIDTHS, IMAGE_FORMATS } from '$lib/images';
import { formatDateDisplay, sortPositionsByDate } from '$lib/util/helper';

interface Props {
	entry: WorkEntry;
	relatedProjects: Array<{ slug: string; title: string }>;
	featured?: boolean;
	class?: string;
}

const { entry, relatedProjects, featured = false, class: className } = Astro.props;
const sortedPositions = sortPositionsByDate(entry.positions);
const hasImage = entry.image && entry.image !== 'TODO';
const isSvg = hasImage ? isSvgImage(entry.image) : false;
const imageData = hasImage && !isSvg ? getWorkImage(entry.image) : null;
---

<Entry
	variant="card"
	href={`/work/${entry.slug}`}
	title={entry.title}
	meta={entry.location}
	featured={featured}
	class={className}
	aria-label={`View details for ${entry.title}`}
>
	{
		isSvg ? (
			<img slot="media" src={`/work/${entry.image}`} alt={entry.title} />
		) : (
			imageData && (
				<Picture
					slot="media"
					src={imageData}
					widths={IMAGE_WIDTHS}
					formats={IMAGE_FORMATS}
					sizes="(min-width:768px) 64px, 48px"
					alt={entry.title}
					loading="lazy"
					decoding="async"
				/>
			)
		)
	}
	<div class="positions">
		{
			sortedPositions.map((position) => (
				<div class="row">
					<span class="position-title">{position.title}</span>
					<span class="dates">
						{formatDateDisplay(position.startDate)} –{' '}
						{position.endDate ? formatDateDisplay(position.endDate) : 'Present'}
					</span>
				</div>
			))
		}
	</div>
	<p class="description">{entry.description}</p>
	<div class="card-footer">
		{
			relatedProjects.length > 0 ? (
				<span>{relatedProjects.map((project) => project.title).join(', ')}</span>
			) : (
				<span>No projects</span>
			)
		}
	</div>
</Entry>

<style>
	.positions {
		display: flex;
		width: 100%;
		min-width: 0;
		flex-direction: column;
		gap: var(--xs);
		.row {
			display: grid;
			width: 100%;
			align-items: baseline;
			gap: var(--m);
			grid-template-columns: 1fr auto;
			color: var(--c-font-accent-dark);
			font-family: var(--font-family);
			font-size: var(--font-s);
			line-height: 1.5;
		}
		.position-title {
			min-width: 0;
			font-weight: 500;
		}
		.dates {
			font-weight: 400;
			text-align: right;
			white-space: nowrap;
		}
	}
	.description {
		margin: 0;
		color: var(--c-font-accent-dark);
		font-family: var(--font-family);
		font-size: var(--font-m);
		font-weight: 400;
		line-height: 1.5;
	}
	.card-footer {
		margin-top: auto;
		padding-top: var(--m);
		width: 100%;
		border-top: 1px solid var(--c-line);
		color: var(--c-font-accent-dark);
		font-family: var(--font-family);
		font-size: var(--font-s);
		font-weight: 400;
		line-height: 1.5;
	}
	:global(.entry.featured) {
		.positions .row,
		.description,
		.card-footer {
			color: var(--c-inverted-text-muted);
		}
		.card-footer {
			border-top-color: var(--c-inverted-line);
		}
	}
</style>
