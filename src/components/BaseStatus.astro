---
import { Icon } from 'astro-icon/components';
import type { StatusFilter } from '$lib/types/entry';

interface Props {
	status: StatusFilter;
}

const { status } = Astro.props;
---

{
	status === 'active' ? (
		<Icon class="status-icon active" name="ph:play-circle-bold" />
	) : (
		<Icon class="status-icon inactive" name="ph:pause-circle-bold" />
	)
}

<style>
	:global(.status-icon) {
		margin: 0 0 -0.25rem 1px;
	}
</style>
