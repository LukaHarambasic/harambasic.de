---
import BaseCard from './BaseCard.astro';
import BaseRichText from './BaseRichText.astro';

interface Props {
	prefix: string;
	class?: string;
	id?: string;
	/** When true, render without outer BaseCard (inner label + content only) */
	noCard?: boolean;
}

const { prefix, class: className, id, noCard = false } = Astro.props;
---

<div class:list={['callout-wrapper', { noCard }]}>
	{
		noCard ? (
			<div class="callout" id={id}>
				{prefix && <strong>{prefix}</strong>}
				<BaseRichText class="content">
					<slot />
				</BaseRichText>
			</div>
		) : (
			<BaseCard class={className ? `callout ${className}` : 'callout'} id={id}>
				{prefix && <strong>{prefix}</strong>}
				<BaseRichText class="content">
					<slot />
				</BaseRichText>
			</BaseCard>
		)
	}
</div>

<style>
	.callout-wrapper {
		display: block;
		&.noCard {
			width: fit-content;
		}
	}
	:global(.callout-wrapper .callout) {
		display: flex;
		align-items: flex-start;
		gap: var(--m);
		strong {
			display: inline-block;
			padding: var(--s) var(--m);
			border: var(--border);
			border-radius: var(--border-radius-small);
			background: var(--c-surface-accent);
			flex: 1 0 auto;
			font-family: var(--font-family);
			font-size: var(--font-m);
			font-weight: 600;
		}
		:global(.content) {
			flex: 0 1 auto;
		}
	}
</style>
