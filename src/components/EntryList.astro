---
/**
 * Layout shell for Entry items. Callers render `<li>` children:
 * columns=1 → stacked items, rule-separated (divided) or gap-separated,
 * columns=2/3/4 → grid with the shared gutter.
 */
interface Props {
	columns?: 1 | 2 | 3 | 4;
	divided?: boolean;
	class?: string;
}

const { columns = 1, divided = true, class: className } = Astro.props;
---

<!-- The wrapper establishes the @container query context: a container query can
     never match the container element itself, so the list needs an ancestor. -->
<div class="entry-list-container">
	<ul
		class:list={['entry-list', className]}
		data-columns={columns}
		data-divided={columns === 1 && divided ? 'true' : 'false'}
	>
		<slot />
	</ul>
</div>

<style>
	.entry-list-container {
		width: 100%;
		container-type: inline-size;
		container-name: entry-list;
	}
	.entry-list {
		margin: 0;
		padding: 0;
		width: 100%;
		list-style: none;

		> :global(li[hidden]) {
			display: none;
		}

		&[data-columns='1'] {
			display: flex;
			flex-direction: column;
			&[data-divided='false'] {
				gap: var(--l);
			}

			/* Minimal air between the hover fill and the divider hairline. */
			&[data-divided='true'] {
				> :global(li:not(:last-child)) {
					padding-block-end: var(--xs);
					border-block-end: 1px solid var(--c-line);
				}
				> :global(li:not(:first-child)) {
					padding-block-start: var(--xs);
				}
			}
		}

		&[data-columns='2'],
		&[data-columns='3'],
		&[data-columns='4'] {
			display: grid;
			align-items: stretch;
			gap: var(--l);
			> :global(li) {
				display: flex;
				min-width: 0;
			}
			> :global(li[hidden]) {
				display: none;
			}
			> :global(li > .entry) {
				flex: 1;
			}
		}
		&[data-columns='2'] {
			grid-template-columns: repeat(2, minmax(0, 1fr));
			@container entry-list (width <= 40rem) {
				grid-template-columns: 1fr;
			}
		}
		&[data-columns='3'] {
			grid-template-columns: repeat(3, minmax(0, 1fr));
			@container entry-list (width <= 54rem) {
				grid-template-columns: repeat(2, minmax(0, 1fr));
			}
			@container entry-list (width <= 40rem) {
				grid-template-columns: 1fr;
			}
		}
		&[data-columns='4'] {
			gap: var(--m);
			grid-template-columns: repeat(4, minmax(0, 1fr));
			@container entry-list (width <= 54rem) {
				grid-template-columns: repeat(2, minmax(0, 1fr));
			}
			@container entry-list (width <= 34rem) {
				grid-template-columns: 1fr;
			}
		}
	}
</style>
