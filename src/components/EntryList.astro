---
/**
 * Layout shell for Entry items. Callers render `<li>` children:
 * columns=1 → stacked items, rule-separated (divided) or gap-separated,
 * columns=2/3/4 → grid with the shared gutter.
 */
interface Props {
	columns?: 1 | 2 | 3 | 4;
	divided?: boolean;
	class?: string;
}

const { columns = 1, divided = true, class: className } = Astro.props;
---

<ul
	class:list={['entry-list', className]}
	data-columns={columns}
	data-divided={columns === 1 && divided ? 'true' : 'false'}
>
	<slot />
</ul>

<style>
	.entry-list {
		margin: 0;
		padding: 0;
		width: 100%;
		list-style: none;

		> :global(li[hidden]) {
			display: none;
		}

		&[data-columns='1'] {
			display: flex;
			flex-direction: column;
			&[data-divided='false'] {
				gap: var(--l);
			}
			/* Minimal air between the hover fill and the divider hairline. */
			&[data-divided='true'] {
				> :global(li:not(:last-child)) {
					padding-bottom: var(--xs);
					border-bottom: 1px solid var(--c-line);
				}
				> :global(li:not(:first-child)) {
					padding-top: var(--xs);
				}
			}
		}

		&[data-columns='2'],
		&[data-columns='3'],
		&[data-columns='4'] {
			display: grid;
			align-items: stretch;
			gap: var(--l);
			> :global(li) {
				display: flex;
				min-width: 0;
			}
			> :global(li[hidden]) {
				display: none;
			}
			> :global(li > .entry) {
				flex: 1;
			}
		}
		&[data-columns='2'] {
			grid-template-columns: repeat(2, minmax(0, 1fr));
			@media screen and (width <= 48rem) {
				grid-template-columns: 1fr;
			}
		}
		&[data-columns='3'] {
			grid-template-columns: repeat(3, minmax(0, 1fr));
			@media screen and (width <= 62rem) {
				grid-template-columns: repeat(2, minmax(0, 1fr));
			}
			@media screen and (width <= 48rem) {
				grid-template-columns: 1fr;
			}
		}
		&[data-columns='4'] {
			gap: var(--m);
			grid-template-columns: repeat(4, minmax(0, 1fr));
			@media screen and (width <= 62rem) {
				grid-template-columns: repeat(2, minmax(0, 1fr));
			}
			@media screen and (width <= 42rem) {
				grid-template-columns: 1fr;
			}
		}
	}
</style>
