---
const links: Array<{ name: string; url: string; isCta?: boolean }> = [
	{ name: 'Home', url: '/' },
	{ name: 'Experience', url: '/experience' },
	{ name: 'Uses', url: '/uses' },
	{ name: 'Posts', url: '/posts' },
	{ name: 'Work with me', url: '/consulting', isCta: true }
];

const pathname = Astro.url.pathname;
// Matches the old loose `includes` rule exactly: '/posts/some-slug' keeps Posts active.
function isActiveRoute(url: string): boolean {
	if (url === '/' && pathname === '/') return true;
	if (url !== '/') return pathname.includes(url);
	return false;
}
---

<header>
	<a class="logo" href="/">
		<img src="/logo.svg" alt="" width="32" height="32" class="mark" />
		<span class="wordmark"><span>Luka</span><span>Harambasic</span></span>
	</a>
	<nav aria-label="Main">
		<ul>
			{
				links.map(({ name, url, isCta }) => (
					<li>
						<a href={url} class:list={[{ 'is-active': isActiveRoute(url), cta: isCta }]}>
							{name}
						</a>
					</li>
				))
			}
		</ul>
	</nav>
</header>

<style>
	header {
		display: flex;
		width: 100%;
		flex-direction: row;
		flex-wrap: nowrap;
		justify-content: space-between;
		align-items: flex-start;
		align-content: stretch;
		@media screen and (width <= 48rem) {
			flex-direction: column;
			align-items: center;
			gap: var(--l);
		}
	}
	.logo {
		display: flex;
		align-items: center;
		gap: var(--xs);
		color: var(--c-font);
		font-size: var(--font-m);
		font-weight: 700;
		line-height: 1.2;
		text-decoration: none;
		@media screen and (width <= 48rem) {
			text-align: center;
		}
		&:hover {
			text-decoration: underline;
			text-decoration-thickness: var(--underline-thickness);
		}
		.wordmark {
			display: flex;
			flex-direction: column;
		}
		.mark {
			display: block;
			width: 2.4em;
			height: 2.4em;
			flex-shrink: 0;
		}
	}
	nav {
		ul {
			display: flex;
			flex-direction: row;
			flex-wrap: nowrap;
			justify-content: flex-start;
			align-items: flex-start;
			align-content: stretch;
			gap: var(--xxs);
			@media screen and (width <= 48rem) {
				flex-wrap: wrap;
				justify-content: center;
			}
			li {
				a {
					display: block;
					padding: var(--xxs) var(--s);

					/* Always-on transparent border so the active state doesn't shift layout. */
					border-block-end: var(--underline-thickness) solid transparent;
					border-radius: var(--border-radius-pill);
					color: var(--c-font);
					font-size: var(--font-m);
					font-weight: 600;
					text-decoration: none;

					/* Background fades as usual; the underline color and radius switch instantly, no morph. */
					transition:
						background var(--transition-time) var(--transition-ease),
						border-block-end-color 0s;
					&:hover {
						background: var(--c-surface-accent);
					}
				}
				.is-active {
					/* Flat underline at rest; on hover the pill background takes over (radius back, no border). */
					border-block-end-color: var(--c-font);
					border-radius: 0;
					&:hover {
						border-block-end-color: transparent;
						border-radius: var(--border-radius-pill);
					}
				}
				.cta {
					border-block-end-color: transparent;
					background: var(--c-inverted);
					color: var(--c-inverted-text);
					transition: var(--transition);
					&:hover {
						box-shadow: var(--shadow-md);
						background: var(--c-inverted);
						transform: translateY(-2px);
					}
				}
			}
		}
	}
</style>
