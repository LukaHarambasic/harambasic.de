---
import { getCollection, render } from 'astro:content';
import { Picture } from 'astro:assets';
import Layout from '../../layouts/Layout.astro';
import BaseRichText from '../../components/BaseRichText.astro';
import DetailLayout from '../../components/DetailLayout.astro';
import EntryHeader from '../../components/EntryHeader.astro';
import { getExperienceImage, isSvgImage, IMAGE_WIDTHS, IMAGE_FORMATS } from '$lib/images';
import { formatDateDisplay, sortPositionsByDate, getSlug } from '$lib/util/helper';
import { renderPositionContent } from '$lib/markdown';

export async function getStaticPaths() {
	const entries = await getCollection('experience');
	return entries.map((entry) => ({
		params: { slug: getSlug(entry.data.title) },
		props: { entry }
	}));
}

const { entry } = Astro.props;
const data = entry.data;
const { Content } = await render(entry);
const hasBody = (entry.body ?? '').trim().length > 0;

const sortedPositions = await Promise.all(
	sortPositionsByDate(data.positions).map(async (position) => ({
		...position,
		content: await renderPositionContent(position.content)
	}))
);

const image = data.image;
const isSvg = !!image && image !== 'TODO' && isSvgImage(image);
const experienceImageData =
	!!image && image !== 'TODO' && !isSvg ? getExperienceImage(image) : null;
const hasLeadingContent = isSvg || !!experienceImageData;
---

<Layout title={data.title} description={data.description} isDetailPage>
	<DetailLayout class="h-entry experience-entry">
		<EntryHeader title={data.title} leadingPosition="inline">
			{
				hasLeadingContent && (
					<div slot="leading" class="icon">
						{isSvg ? (
							<img src={`/experience/${image}`} alt={data.title} />
						) : (
							experienceImageData && (
								<Picture
									src={experienceImageData}
									widths={IMAGE_WIDTHS}
									formats={IMAGE_FORMATS}
									sizes="(min-width:768px) 64px, 48px"
									alt={data.title}
									loading="lazy"
									decoding="async"
								/>
							)
						)}
					</div>
				)
			}
			<Fragment slot="meta">{data.location}</Fragment>
		</EntryHeader>

		{data.description && <p class="description">{data.description}</p>}

		{
			sortedPositions.length > 0 && (
				<div class="positions">
					{sortedPositions.map((position) => (
						<section class="position-section">
							<header class="position-header">
								<div class="position-title-group">
									<h2 class="position-title">{position.title}</h2>
									{position.employmentType && (
										<p class="employment-type">{position.employmentType}</p>
									)}
								</div>
								<p class="position-dates">
									<time datetime={position.startDate}>{formatDateDisplay(position.startDate)}</time>{' '}
									–{' '}
									{position.endDate ? (
										<time datetime={position.endDate}>{formatDateDisplay(position.endDate)}</time>
									) : (
										'Present'
									)}
								</p>
							</header>
							<div class="position-content">
								<BaseRichText>
									<Fragment set:html={position.content} />
								</BaseRichText>
							</div>
						</section>
					))}
				</div>
			)
		}

		{
			hasBody && (
				<BaseRichText class="content">
					<Content />
				</BaseRichText>
			)
		}
	</DetailLayout>
</Layout>

<style>
	.icon {
		display: flex;
		width: 4rem;
		height: 4rem;
		flex-shrink: 0;
		flex-direction: row;
		justify-content: center;
		align-items: center;
		overflow: hidden;
		img,
		:global(picture) {
			display: block;
			margin: 0;
			padding: 0;
			width: 100%;
			height: 100%;
			border-radius: var(--border-radius-small);
			object-fit: contain;
		}
	}
	.description {
		margin: 0;
		color: var(--c-font-accent-dark);
		font-size: var(--font-m);
		line-height: 1.5;
	}
	.positions {
		display: flex;
		width: 100%;
		flex-direction: column;
		gap: var(--l);
	}
	.position-section {
		display: flex;
		padding-block-end: var(--l);
		border-block-end: 1px solid var(--c-line);
		flex-direction: column;
		gap: var(--s);
		&:last-child {
			padding-block-end: 0;
			border-block-end: none;
		}
	}
	.position-header {
		display: flex;
		justify-content: space-between;
		align-items: flex-start;
		gap: var(--m);
		@media screen and (width <= 48rem) {
			flex-direction: column;
			align-items: flex-start;
			gap: var(--xs);
		}
	}
	.position-title-group {
		display: flex;
		flex: 1;
		flex-direction: column;
		align-items: flex-start;
		gap: var(--xs);
	}
	.position-title {
		margin: 0;
		color: var(--c-font);
		font-family: var(--font-family-serif);
		font-size: var(--fs-h3);
		font-weight: 500;
		letter-spacing: var(--tracking-heading);
	}
	.employment-type {
		margin: 0;
		color: var(--c-font-accent-dark);
		font-size: var(--font-s);
		font-style: italic;
		line-height: 1.5;
		text-transform: capitalize;
	}
	.position-dates {
		margin: 0;
		flex-shrink: 0;
		color: var(--c-font-accent-dark);
		font-size: var(--font-s);
		line-height: 1.5;
		white-space: nowrap;
	}

	/* Prose styling comes from BaseRichText so the body reads exactly like
	   the posts details. */
	.content {
		width: 100%;
	}
</style>
