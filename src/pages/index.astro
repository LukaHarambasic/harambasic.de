---
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import BaseRichText from '../components/BaseRichText.astro';
import BaseSegmentedButtons from '../components/BaseSegmentedButtons.astro';
import EntryList from '../components/EntryList.astro';
import ExperienceCard from '../components/ExperienceCard.astro';
import JsonLd from '../components/JsonLd.astro';
import { personSchema, websiteSchema } from '$lib/jsonld';
import profileImg from '../assets/img/profile.jpeg';
import { getExperience } from '$lib/content';
import type { ExperienceEntry } from '$lib/types/experienceEntry';

const description =
	'Luka Harambasic. Product and AI consulting, past work in climate tech and energy. Based in Copenhagen.';

const experience = await getExperience();

// Most recent roles by latest position start date (current roles sort first naturally).
const latestStart = (entry: ExperienceEntry): number =>
	Math.max(...entry.positions.map((position) => new Date(position.startDate).getTime()));
const recentExperience = [...experience]
	.sort((a, b) => latestStart(b) - latestStart(a))
	.slice(0, 3);
---

<Layout description={description}>
	<Fragment slot="head">
		<JsonLd schema={personSchema()} />
		<JsonLd schema={websiteSchema()} />
	</Fragment>
	<section class="heyho">
		<h1>Heyho,<br />I'm Luka!</h1>
		<div class="inner">
			{
				/* LCP element: load eagerly at high priority, sized to its real display width
			    (14.5rem desktop, full container width below 32rem) instead of the shared
			    detail-page widths - the old sizes pulled the 1280w variant for a ~350px slot. */
			}
			<Image
				src={profileImg}
				alt="Profile of Luka Harambasic"
				class="profile"
				widths={[232, 464, 696]}
				sizes="(max-width: 32rem) calc(100vw - 4rem), 14.5rem"
				loading="eager"
				fetchpriority="high"
			/>
			<BaseRichText class="bio">
				<p>
					German/Croatian living in Copenhagen. By day I'm a product manager (new gig starting in
					August), and next to that I do <a href="/consulting">consulting</a>: AI, automation, and
					product for startups. This site has been around for years, rebuilt every time a new
					framework caught my eye. It's my little playground on the web, and the place to learn what
					I can help you with. If you want to geek out over AI and automation, or talk handball,
					woodworking, or cooking, <a href="#contact">say hi</a>.
				</p>
			</BaseRichText>
		</div>
	</section>
	<section class="highlights">
		<p class="eyebrow">Experience</p>
		<h2>Where I've worked and what I built</h2>
		<EntryList columns={3}>
			{
				recentExperience.map((entry) => (
					<li>
						<ExperienceCard entry={entry} />
					</li>
				))
			}
		</EntryList>
		<a class="more-link" href="/experience">All experience</a>
	</section>
	<section class="consulting-banner">
		<p class="eyebrow">Harambasic Consulting</p>
		<h2>I help you put AI to work.</h2>
		<p class="sub">
			Strategy and execution across AI, automation, and product for startups. I advise and I build,
			sometimes in the same day.
		</p>
		<a class="btn-book" href="https://cal.com/luhara/harambasic-consulting">Book a call</a>
	</section>
	<section class="contact golden-ratio">
		<p class="eyebrow">Get in touch</p>
		<h2>Say hi.</h2>
		<p class="sub">
			Drop a line. Talk AI, automation, product direction, or just say hi. Pick whatever channel
			works.
		</p>
		<dl class="channels">
			<div class="group">
				<dt class="meta">
					<strong>E-Mail</strong>
					<small>luka@harambasic.de</small>
				</dt>
				<dd>
					<BaseSegmentedButtons>
						<a href="mailto:luka@harambasic.de">Write</a>
						<button class="button" type="button" data-clipboard="luka@harambasic.de">Copy</button>
					</BaseSegmentedButtons>
				</dd>
			</div>
			<div class="group">
				<dt class="meta">
					<strong>Socials</strong>
					<small>Get in touch!</small>
				</dt>
				<dd>
					<BaseSegmentedButtons>
						<a
							href="https://signal.me/#eu/nEQUfJVmtAbHirhDccRIQMkqWOiIiq2/7VROG9o/YrlzrC9ejHlCxYgFg1HMGx2B"
							>Signal</a
						>
						<a href="https://www.linkedin.com/in/harambasic/">LinkedIn</a>
						<a href="https://bsky.app/profile/harambasic.de">BlueSky</a>
						<a href="https://github.com/LukaHarambasic">GitHub</a>
					</BaseSegmentedButtons>
				</dd>
			</div>
			<div class="group">
				<dt class="meta">
					<strong>Book a time</strong>
					<small>Wanna talk?</small>
				</dt>
				<dd>
					<BaseSegmentedButtons>
						<a href="https://cal.com/luhara/1">Book</a>
					</BaseSegmentedButtons>
				</dd>
			</div>
		</dl>
	</section>
</Layout>

<style>
	.eyebrow {
		margin: 0;
		color: var(--c-font-accent-dark);
		font-family: var(--font-family-code);
		font-size: var(--font-s);
		font-weight: 500;
		letter-spacing: var(--tracking-eyebrow);
		text-transform: uppercase;
		&::after {
			display: block;
			margin-block-start: var(--s);
			width: var(--deco-bar-width);
			height: var(--deco-bar-height);
			border-radius: var(--deco-bar-radius);
			background: var(--deco-bar-color);
			content: '';
		}
	}
	.heyho {
		display: flex;
		position: relative;
		margin-block-start: var(--xl);
		width: var(--layout-l);
		flex-direction: column;
		gap: var(--l);
		@media screen and (width <= 56rem) {
			width: 100%;
		}
		h1 {
			margin: 0;
			font-family: var(--font-family-serif);
			font-size: clamp(3rem, 9vw, 6rem);
			font-weight: 600;
			line-height: 1;
			letter-spacing: var(--tracking-display);
			text-align: center;
			white-space: nowrap;

			/* Subtle brand gradient; only when the text can actually carry it */
			@supports (background-clip: text) or (-webkit-background-clip: text) {
				background: linear-gradient(105deg, var(--c-font) 55%, var(--c-accent-italic));
				background-clip: text;
				color: transparent;
			}
		}
		.inner {
			display: flex;
			align-items: flex-start;
			gap: var(--l);
			@media screen and (width <= 48rem) {
				flex-direction: column;
			}
			.profile {
				size: 14.5rem;
				border-radius: var(--border-radius);
				@media screen and (width <= 32rem) {
					width: 100%;
					height: auto;
				}
			}
			:global(.bio p) {
				font-weight: normal;
				line-height: 1.5;
				a {
					line-break: loose;
				}
			}
		}
	}
	.consulting-banner {
		display: flex;
		margin-block-start: var(--xl);
		padding: var(--l);
		width: var(--layout-l);
		border-radius: var(--border-radius);
		background: var(--c-inverted);
		flex-direction: column;
		align-items: flex-start;
		gap: var(--m);

		--deco-bar-color: var(--c-accent-honey);

		@media screen and (width <= 56rem) {
			width: 100%;
		}
		@media screen and (width <= 30rem) {
			padding: var(--m);
		}
		.eyebrow {
			color: var(--c-inverted-text-muted);
		}
		h2 {
			margin: 0;
			color: var(--c-inverted-text);
			font-family: var(--font-family-serif);
			font-size: var(--fs-h1);
			font-weight: 500;
			letter-spacing: var(--tracking-heading);
			text-wrap: balance;
		}
		.sub {
			margin: 0;
			max-width: 36rem;
			color: var(--c-inverted-text-muted);
			font-size: var(--font-m);
			line-height: 1.5;
		}
		.btn-book {
			padding: var(--xs) var(--m);
			border-radius: var(--border-radius-pill);
			background: var(--c-inverted-text);
			color: var(--c-inverted);
			font-size: var(--font-m);
			font-weight: 600;
			text-decoration: none;
			transition: var(--transition);
			&:hover {
				box-shadow: var(--shadow-md);
				transform: translateY(-2px);
			}
		}
	}
	.highlights {
		display: flex;
		margin-block-start: var(--xl);
		width: 100%;
		flex-direction: column;
		gap: var(--l);
		h2 {
			margin: 0;
			font-family: var(--font-family-serif);
			font-size: var(--fs-h2);
			font-weight: 500;
			line-height: 1.2;
			letter-spacing: var(--tracking-heading);
		}
		.more-link {
			align-self: flex-start;
			color: var(--c-font);
			font-size: var(--font-m);
			font-weight: 500;
			text-decoration: underline;
			text-decoration-thickness: var(--underline-thickness);
			&:hover {
				text-decoration: none;
			}
		}
	}
	.contact {
		display: flex;
		margin-block-start: var(--xl);
		flex-direction: column;
		align-items: flex-start;
		gap: var(--m);
		h2 {
			margin: 0;
			font-family: var(--font-family-serif);
			font-size: var(--fs-h2);
			font-weight: 500;
			letter-spacing: var(--tracking-heading);
		}
		.sub {
			margin: 0;
			max-width: 36rem;
			color: var(--c-font-accent-dark);
			font-size: var(--font-m);
			line-height: 1.5;
		}
		.channels {
			display: flex;
			margin: 0;
			width: 100%;
			flex-direction: column;
			.group {
				display: flex;
				padding: var(--l);
				border-block-end: 1px solid var(--c-border);
				flex-direction: row;
				justify-content: space-between;
				align-items: flex-start;
				@media screen and (width <= 48rem) {
					flex-direction: column;
					gap: var(--l);
				}
				dd {
					margin: 0;
				}
				.meta {
					display: flex;
					flex-direction: column;
					strong {
						margin-block-end: var(--xs);
						font-size: var(--font-m);
						font-weight: 600;
						line-height: 1.2;
					}
					small {
						font-size: var(--font-s);
					}
				}
			}
		}
	}
</style>
