---
import { Image, Picture } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import BaseRichText from '../components/BaseRichText.astro';
import Entry from '../components/Entry.astro';
import EntryList from '../components/EntryList.astro';
import { Icon } from 'astro-icon/components';
import profileImg from '../assets/img/profile.jpeg';
import { getPosts, getProjects, getUses, getWork } from '$lib/content';
import { getMergedFeedEntries, type MergedFeedEntry } from '$lib/util/mergedFeed';
import {
	getProjectImage,
	getUsesImage,
	getWorkImage,
	isSvgImage,
	IMAGE_WIDTHS,
	IMAGE_FORMATS
} from '$lib/images';

const description =
	'My private playground, publishing my thoughts and ideas. Showing of what I did and playing around with new technologies.';

const SVG_PATH_PREFIX: Record<string, string> = {
	Projects: '/projects/',
	Uses: '/uses/',
	Work: '/work/'
};
const getSvgSrc = (category: string, imageName: string) =>
	SVG_PATH_PREFIX[category] ? `${SVG_PATH_PREFIX[category]}${imageName}` : '';
function getEntryImage(entry: { category: string; image: string }) {
	if (entry.category === 'Projects') return getProjectImage(entry.image);
	if (entry.category === 'Uses') return getUsesImage(entry.image);
	if (entry.category === 'Work') return getWorkImage(entry.image);
	return null;
}

const [posts, projects, uses, work] = await Promise.all([
	getPosts(),
	getProjects(),
	getUses(),
	getWork()
]);

// One stream, sorted by last update; the newest entry is the featured card,
// the rest render as calm single-column rows.
const merged = getMergedFeedEntries(posts, projects, uses, work);
const [latest, ...rows] = merged;

const INITIAL_ROWS = 6;
const STEP = 6;
const steps: number[] = [];
for (let n = Math.min(INITIAL_ROWS, rows.length); ; n += STEP) {
	n = Math.min(n, rows.length);
	steps.push(n);
	if (n >= rows.length) break;
}

const rowMedia = (entry: MergedFeedEntry) => ({
	isPost: entry.category === 'Posts',
	isSvg: !!entry.image && isSvgImage(entry.image),
	imageData: entry.image ? getEntryImage(entry) : null
});
---

<Layout description={description}>
	<section class="heyho">
		<div class="inner">
			{
				/* LCP element: load eagerly at high priority, sized to its real display width
			    (14.5rem desktop, full container width below 32rem) instead of the shared
			    detail-page widths — the old sizes pulled the 1280w variant for a ~350px slot. */
			}
			<Image
				src={profileImg}
				alt="Profile of Luka Harambasic"
				class="profile"
				widths={[232, 464, 696]}
				sizes="(max-width: 32rem) calc(100vw - 4rem), 14.5rem"
				loading="eager"
				fetchpriority="high"
			/>
			<div class="content">
				<BaseRichText>
					<h1>Heyho, I'm Luka!</h1>
					<p>
						I'm a German/Croatian, based in the beautiful Copenhagen (Denmark). Right now, I'm
						building with the PLG squad at <a href="https://www.electricitymaps.com/"
							>Electricity Maps</a
						>. Feel free to explore my past
						<a href="/projects">projects</a>
						or check out my <a href="https://www.linkedin.com/in/harambasic/">LinkedIn profile</a>.
						I'm right now incredibly hyped about automation and AI. Whether you want to geek out
						over that or start a conversation about handball, woodworking, cooking, and
						sustainability, feel free to <a href="#contact">say hi</a>.
					</p>
				</BaseRichText>
			</div>
		</div>
	</section>
	<section class="featured">
		<h2>Feed</h2>
		<p class="feed-intro">
			A combined feed of everything on this site: posts, projects, uses, and work. Ordered by last
			updated, so sometimes old entries might appear at the top.
		</p>
		<div class="feed" data-feed-steps={JSON.stringify(steps)}>
			{
				latest && (
					<Entry
						variant="card"
						featured
						href={latest.href}
						title={latest.title}
						titleTag="h3"
						eyebrow={latest.category}
						meta={latest.updated.display}
						metaDatetime={latest.updated.raw.toISOString()}
						excerpt={latest.description}
						external={latest.isExternal}
						aria-label={`View ${latest.title}`}
					/>
				)
			}
			<EntryList>
				{
					rows.map((entry, index) => {
						const media = rowMedia(entry);
						return (
							<li data-feed-item hidden={index >= INITIAL_ROWS}>
								<Entry
									href={entry.href}
									title={entry.title}
									titleTag="h3"
									eyebrow={entry.category}
									meta={entry.updated.display}
									metaDatetime={entry.updated.raw.toISOString()}
									excerpt={entry.description}
									external={entry.isExternal}
									aria-label={`View ${entry.title}`}
								>
									{media.isPost ? (
										<Icon slot="media" name="ph:file-text-duotone" class="thumb-icon" />
									) : media.isSvg ? (
										<img
											slot="media"
											src={getSvgSrc(entry.category, entry.image)}
											alt={entry.title}
											loading="lazy"
										/>
									) : media.imageData ? (
										<Picture
											slot="media"
											src={media.imageData}
											widths={IMAGE_WIDTHS}
											formats={IMAGE_FORMATS}
											sizes="(min-width:768px) 64px, 48px"
											alt={entry.title}
											loading="lazy"
											decoding="async"
										/>
									) : (
										<Icon slot="media" name="ph:empty-duotone" class="thumb-icon" />
									)}
								</Entry>
							</li>
						);
					})
				}
			</EntryList>
			<div class="actions">
				<button type="button" class="btn" data-feed-more hidden={steps.length <= 1}
					>Show more</button
				>
				<button type="button" class="btn" data-feed-less hidden>Show less</button>
			</div>
		</div>
	</section>
</Layout>

<style>
	.heyho {
		display: flex;
		position: relative;
		margin: var(--xl) 0;
		width: var(--layout-l);
		flex-direction: column;
		flex-wrap: nowrap;
		justify-content: flex-start;
		align-items: stretch;
		align-content: stretch;
		gap: var(--l);
		@media screen and (width <= 56rem) {
			width: 100%;
		}
		.inner {
			display: flex;
			flex-direction: row;
			flex-wrap: nowrap;
			justify-content: flex-start;
			align-items: flex-start;
			align-content: stretch;
			gap: var(--l);
			@media screen and (width <= 44rem) {
				flex-direction: column;
			}
			.profile {
				size: 14.5rem;
				border-radius: var(--border-radius);
				@media screen and (width <= 32rem) {
					width: 100%;
					height: auto;
				}
			}
			.content {
				h1 {
					margin: 0 0 var(--s);
					font-family: var(--font-family-serif);
					font-size: var(--fs-h1);
					font-weight: 600;
					letter-spacing: var(--tracking-heading);
				}
				p {
					font-weight: normal;
					line-height: 1.5;
					a {
						line-break: loose;
					}
				}
			}
		}
	}
	.featured {
		display: flex;
		margin: 0 auto;
		width: 100%;
		max-width: calc(var(--layout-xl) * 0.618);
		flex-direction: column;
		flex-wrap: nowrap;
		justify-content: flex-start;
		align-items: stretch;
		align-content: stretch;
		gap: var(--l);

		h2 {
			margin: var(--xl) 0 var(--m) 0;
			font-family: var(--font-family-serif);
			font-size: var(--fs-h2);
			font-weight: 500;
			line-height: 1.2;
			letter-spacing: var(--tracking-heading);
			text-align: center;
			&::after {
				display: block;
				margin: var(--s) auto 0;
				width: 3.5rem;
				height: 2px;
				border-radius: 1px;
				background: var(--c-font);
				content: '';
			}
		}

		.feed-intro {
			margin: 0 0 var(--l);
			max-width: 36rem;
			align-self: center;
			color: var(--c-font-accent-dark);
			font-size: var(--font-m);
			line-height: 1.5;
			text-align: center;
		}

		.feed {
			display: flex;
			width: 100%;
			flex-direction: column;
			gap: var(--l);
			:global(.thumb-icon) {
				display: block;
				padding: var(--s);
				width: 100%;
				height: auto;
				min-height: 3rem;
				color: var(--c-font-accent-dark);
			}
		}

		.actions {
			display: flex;
			flex-wrap: wrap;
			justify-content: center;
			gap: var(--m);
		}

		.btn {
			padding: var(--s) var(--m);
			border: 1px solid var(--c-line);
			border-radius: var(--border-radius);
			background: var(--c-tint);
			color: var(--c-font);
			font-family: var(--font-family);
			font-size: var(--font-s);
			font-weight: 600;
			transition: var(--transition);
			cursor: pointer;
			&:hover {
				background: color-mix(in srgb, var(--c-surface-accent) 80%, transparent);
			}
		}
	}
</style>
