---
import { Image, Picture } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import BaseRichText from '../components/BaseRichText.astro';
import Entry from '../components/Entry.astro';
import EntryList from '../components/EntryList.astro';
import JsonLd from '../components/JsonLd.astro';
import { personSchema, websiteSchema } from '$lib/jsonld';
import { Icon } from 'astro-icon/components';
import profileImg from '../assets/img/profile.jpeg';
import { getPosts, getProjects, getUses, getWork } from '$lib/content';
import { getMergedFeedEntries, type MergedFeedEntry } from '$lib/util/mergedFeed';
import {
	getProjectImage,
	getUsesImage,
	getWorkImage,
	isSvgImage,
	IMAGE_WIDTHS,
	IMAGE_FORMATS
} from '$lib/images';

const description =
	'Luka Harambasic. Product and AI consulting, past work in climate tech and energy. Based in Copenhagen.';

const SVG_PATH_PREFIX: Record<string, string> = {
	Projects: '/projects/',
	Uses: '/uses/',
	Work: '/work/'
};
const getSvgSrc = (category: string, imageName: string) =>
	SVG_PATH_PREFIX[category] ? `${SVG_PATH_PREFIX[category]}${imageName}` : '';
function getEntryImage(entry: { category: string; image: string }) {
	if (entry.category === 'Projects') return getProjectImage(entry.image);
	if (entry.category === 'Uses') return getUsesImage(entry.image);
	if (entry.category === 'Work') return getWorkImage(entry.image);
	return null;
}

const [posts, projects, uses, work] = await Promise.all([
	getPosts(),
	getProjects(),
	getUses(),
	getWork()
]);

// One stream, sorted by last update, rendered as a two-column row grid.
const rows = getMergedFeedEntries(posts, projects, uses, work);

const INITIAL_ROWS = 6;
const STEP = 6;
const steps: number[] = [];
for (let n = Math.min(INITIAL_ROWS, rows.length); ; n += STEP) {
	n = Math.min(n, rows.length);
	steps.push(n);
	if (n >= rows.length) break;
}

const rowMedia = (entry: MergedFeedEntry) => ({
	isPost: entry.category === 'Posts',
	isSvg: !!entry.image && isSvgImage(entry.image),
	imageData: entry.image ? getEntryImage(entry) : null
});
---

<Layout description={description}>
	<Fragment slot="head">
		<JsonLd schema={personSchema()} />
		<JsonLd schema={websiteSchema()} />
	</Fragment>
	<section class="heyho">
		<h1>Heyho,<br />I'm Luka!</h1>
		<div class="inner">
			{
				/* LCP element: load eagerly at high priority, sized to its real display width
			    (14.5rem desktop, full container width below 32rem) instead of the shared
			    detail-page widths - the old sizes pulled the 1280w variant for a ~350px slot. */
			}
			<Image
				src={profileImg}
				alt="Profile of Luka Harambasic"
				class="profile"
				widths={[232, 464, 696]}
				sizes="(max-width: 32rem) calc(100vw - 4rem), 14.5rem"
				loading="eager"
				fetchpriority="high"
			/>
			<BaseRichText class="bio">
				<p>
					German/Croatian living in Copenhagen. By day I'm a product manager (new gig starting in
					August), and next to that I do <a href="/consulting">consulting</a>: AI, automation, and
					product for startups. This site has been around for years, rebuilt every time a new
					framework caught my eye. It's my little playground on the web, and the place to learn what
					I can help you with. If you want to geek out over AI and automation, or talk handball,
					woodworking, or cooking, <a href="#contact">say hi</a>.
				</p>
			</BaseRichText>
		</div>
	</section>
	<section class="consulting-banner">
		<p class="eyebrow">Harambasic Consulting</p>
		<h2>I help you put AI to work.</h2>
		<p class="sub">
			Strategy and execution across AI, automation, and product for startups. I advise and I build,
			sometimes in the same day.
		</p>
		<a class="btn-book" href="https://cal.com/luhara/harambasic-consulting">Book a call</a>
	</section>
	<section class="featured">
		<h2>Feed</h2>
		<p class="feed-intro">
			A combined feed of everything on this site: posts, projects, uses, and work. Ordered by last
			updated, so sometimes old entries might appear at the top.
		</p>
		<div class="feed" data-feed-steps={JSON.stringify(steps)}>
			<EntryList columns={2}>
				{
					rows.map((entry, index) => {
						const media = rowMedia(entry);
						return (
							<li data-feed-item hidden={index >= INITIAL_ROWS}>
								<Entry
									variant="card"
									href={entry.href}
									title={entry.title}
									titleTag="h3"
									eyebrow={entry.category}
									meta={entry.updated.display}
									metaDatetime={entry.updated.raw.toISOString()}
									excerpt={entry.description}
									external={entry.isExternal}
									aria-label={`View ${entry.title}`}
								>
									{media.isPost ? (
										<Icon slot="media" name="ph:file-text-duotone" class="thumb-icon" />
									) : media.isSvg ? (
										<img
											slot="media"
											src={getSvgSrc(entry.category, entry.image)}
											alt={entry.title}
											loading="lazy"
										/>
									) : media.imageData ? (
										<Picture
											slot="media"
											src={media.imageData}
											widths={IMAGE_WIDTHS}
											formats={IMAGE_FORMATS}
											sizes="(min-width:768px) 64px, 48px"
											alt={entry.title}
											loading="lazy"
											decoding="async"
										/>
									) : (
										<Icon slot="media" name="ph:empty-duotone" class="thumb-icon" />
									)}
								</Entry>
							</li>
						);
					})
				}
			</EntryList>
			<div class="actions">
				<button type="button" class="btn" data-feed-more hidden={steps.length <= 1}
					>Show more</button
				>
				<button type="button" class="btn" data-feed-less hidden>Show less</button>
			</div>
		</div>
	</section>
</Layout>

<style>
	.heyho {
		display: flex;
		position: relative;
		margin-block-start: var(--xl);
		width: var(--layout-l);
		flex-direction: column;
		gap: var(--l);
		@media screen and (width <= 56rem) {
			width: 100%;
		}
		h1 {
			margin: 0;
			font-family: var(--font-family-serif);
			font-size: clamp(3rem, 9vw, 6rem);
			font-weight: 600;
			line-height: 1;
			letter-spacing: var(--tracking-display);
			text-align: center;
			white-space: nowrap;

			/* Subtle brand gradient; only when the text can actually carry it */
			@supports (background-clip: text) or (-webkit-background-clip: text) {
				background: linear-gradient(105deg, var(--c-font) 55%, var(--c-accent-italic));
				background-clip: text;
				color: transparent;
			}
		}
		.inner {
			display: flex;
			align-items: flex-start;
			gap: var(--l);
			@media screen and (width <= 48rem) {
				flex-direction: column;
			}
			.profile {
				size: 14.5rem;
				border-radius: var(--border-radius);
				@media screen and (width <= 32rem) {
					width: 100%;
					height: auto;
				}
			}
			:global(.bio p) {
				font-weight: normal;
				line-height: 1.5;
				a {
					line-break: loose;
				}
			}
		}
	}
	.consulting-banner {
		display: flex;
		margin-block-start: var(--xl);
		padding: var(--l);
		width: var(--layout-l);
		border-radius: var(--border-radius);
		background: var(--c-inverted);
		flex-direction: column;
		align-items: flex-start;
		gap: var(--m);

		--deco-bar-color: var(--c-accent-honey);

		@media screen and (width <= 56rem) {
			width: 100%;
		}
		@media screen and (width <= 30rem) {
			padding: var(--m);
		}
		.eyebrow {
			margin: 0;
			color: var(--c-inverted-text-muted);
			font-family: var(--font-family-code);
			font-size: var(--font-s);
			font-weight: 500;
			letter-spacing: var(--tracking-eyebrow);
			text-transform: uppercase;
			&::after {
				display: block;
				margin-block-start: var(--s);
				width: var(--deco-bar-width);
				height: var(--deco-bar-height);
				border-radius: var(--deco-bar-radius);
				background: var(--deco-bar-color);
				content: '';
			}
		}
		h2 {
			margin: 0;
			color: var(--c-inverted-text);
			font-family: var(--font-family-serif);
			font-size: var(--fs-h1);
			font-weight: 500;
			letter-spacing: var(--tracking-heading);
			text-wrap: balance;
		}
		.sub {
			margin: 0;
			max-width: 36rem;
			color: var(--c-inverted-text-muted);
			font-size: var(--font-m);
			line-height: 1.5;
		}
		.btn-book {
			padding: var(--xs) var(--m);
			border-radius: var(--border-radius-pill);
			background: var(--c-inverted-text);
			color: var(--c-inverted);
			font-size: var(--font-m);
			font-weight: 600;
			text-decoration: none;
			transition: var(--transition);
			&:hover {
				box-shadow: var(--shadow-md);
				transform: translateY(-2px);
			}
		}
	}
	.featured {
		display: flex;
		margin-inline: auto;
		width: 100%;
		flex-direction: column;
		gap: var(--l);

		h2 {
			margin: var(--xl) 0 var(--m) 0;
			font-family: var(--font-family-serif);
			font-size: var(--fs-h2);
			font-weight: 500;
			line-height: 1.2;
			letter-spacing: var(--tracking-heading);
			text-align: center;
			&::after {
				display: block;
				margin-block-start: var(--s);
				margin-inline: auto;
				width: var(--deco-bar-width);
				height: var(--deco-bar-height);
				border-radius: var(--deco-bar-radius);
				background: var(--deco-bar-color);
				content: '';
			}
		}

		.feed-intro {
			margin: 0 0 var(--l);
			max-width: 36rem;
			align-self: center;
			color: var(--c-font-accent-dark);
			font-size: var(--font-m);
			line-height: 1.5;
			text-align: center;
		}

		.feed {
			display: flex;
			width: 100%;
			flex-direction: column;
			gap: var(--l);
			:global(.thumb-icon) {
				display: block;
				padding: var(--s);
				width: 100%;
				height: auto;
				min-height: 3rem;
				color: var(--c-font-accent-dark);
			}
		}

		.actions {
			display: flex;
			flex-wrap: wrap;
			justify-content: center;
			gap: var(--m);
		}

		.btn {
			padding: var(--s) var(--m);
			border: 1px solid var(--c-line);
			border-radius: var(--border-radius);
			background: var(--c-tint);
			color: var(--c-font);
			font-size: var(--font-s);
			font-weight: 600;
			transition: var(--transition);
			cursor: pointer;
			&:hover {
				background: color-mix(in srgb, var(--c-surface-accent) 80%, transparent);
			}
		}
	}
</style>
