---
import Layout from '../../layouts/Layout.astro';
import Hero from '../../components/Hero.astro';
import Entries from '../../components/Entries.astro';
import WorkCard from '../../components/WorkCard.astro';
import type { WorkEntry } from '$lib/types/workEntry';
import { getWork, getProjects } from '$lib/content';

const title = 'Building products that matter for people & the planet';
const description =
	"My professional journey across different companies and roles. Each entry represents a company where I've worked, with multiple positions and experiences.";

const workEntries = await getWork();
const projectEntries = await getProjects();

// work slug -> related project {slug,title}[] — same as the old +page.server.ts
const projectMap = new Map(projectEntries.map((p) => [p.slug, { slug: p.slug, title: p.title }]));
const workRelatedProjects: Record<string, Array<{ slug: string; title: string }>> = {};
for (const entry of workEntries) {
	const related = (entry.relatedProjects ?? [])
		.map((slug) => projectMap.get(slug))
		.filter((p): p is { slug: string; title: string } => p !== undefined);
	if (related.length > 0) workRelatedProjects[entry.slug] = related;
}
const getRelatedProjects = (entry: WorkEntry) => workRelatedProjects[entry.slug] ?? [];

// Current = any position with endDate === null; past sorted by most recent start date.
const cards = workEntries.map((entry) => ({
	entry,
	isCurrent: entry.positions.some((position) => position.endDate === null)
}));
const current = cards.find((card) => card.isCurrent) ?? null;
const past = cards
	.filter((card) => !card.isCurrent)
	.sort((a, b) => {
		const aLatest = Math.max(...a.entry.positions.map((p) => new Date(p.startDate).getTime()));
		const bLatest = Math.max(...b.entry.positions.map((p) => new Date(p.startDate).getTime()));
		return bLatest - aLatest;
	});
---

<Layout title={title} description={description}>
	<Hero slot="hero" title={title} description={description} />
	<Entries>
		<div class="work-container">
			{
				current && (
					<WorkCard
						entry={current.entry}
						relatedProjects={getRelatedProjects(current.entry)}
						variant="featured"
						extraClass="current-card"
					/>
				)
			}
			{
				past.length > 0 && (
					<div class="work-grid">
						{past.map((card) => (
							<WorkCard
								entry={card.entry}
								relatedProjects={getRelatedProjects(card.entry)}
								variant="default"
								extraClass="past-card"
							/>
						))}
					</div>
				)
			}
		</div>
	</Entries>
</Layout>

<style>
	.work-container {
		display: flex;
		margin: 0 auto;
		padding: var(--xl) 0;
		width: 100%;
		max-width: var(--layout-xl);
		flex-direction: column;
		gap: var(--xl);

		/* current-card: higher specificity so text colors beat BaseCard's var(--c-font) */
		:global(.base-card.current-card) {
			position: relative;
			margin: 0 auto;
			width: 61.8%;
			height: 100%;
			border-color: rgba(255, 237, 249, 0.18);
			background: var(--c-current-work-bg);
			color: inherit;
			text-decoration: none;
			@media screen and (width <= 48rem) {
				width: 100%;
			}
			&:focus {
				outline: 2px solid var(--c-accent-honey);
				outline-offset: 2px;
			}
			&:hover {
				transform: scale(1.02) translateY(-4px);
				cursor: pointer;
			}
		}
		:global(.past-card) {
			width: 100%;
			&:focus {
				outline: 2px solid var(--c-font);
				outline-offset: 2px;
			}
		}

		.work-grid {
			display: grid;
			gap: var(--l);
			grid-template-columns: repeat(2, 1fr);
			@media screen and (width <= 48rem) {
				gap: var(--l);
				grid-template-columns: 1fr;
			}
			:global(.past-card) {
				display: flex;
				min-height: 100%;
				flex-direction: column;
			}
		}

		/* current-card descendants: light text so readable on dark background */
		:global(.base-card.current-card strong),
		:global(.base-card.current-card time),
		:global(.base-card.current-card p) {
			color: inherit;
			text-decoration: none;
		}
		:global(.base-card.current-card time),
		:global(.base-card.current-card p) {
			opacity: 0.9;
			color: var(--c-current-work-text);
		}
		:global(.base-card.current-card[href] .external-link) {
			color: var(--c-current-work-text);
		}
		:global(.base-card.current-card[href]:hover .external-link) {
			transform: translateY(-2px) translateX(2px);
		}
		:global(.base-card.current-card .logo) {
			background: rgba(255, 237, 249, 0.1);
		}
		:global(.base-card.current-card .name) {
			color: var(--c-current-work-text);
			font-size: 1.5rem;
		}
		:global(.base-card.current-card .location) {
			color: rgba(255, 237, 249, 0.8);
		}
		:global(.base-card.current-card .row) {
			color: rgba(255, 237, 249, 0.8);
		}
		:global(.base-card.current-card .dates) {
			color: rgba(255, 237, 249, 0.8);
		}
		:global(.base-card.current-card .description p) {
			color: var(--c-current-work-text);
		}
		:global(.base-card.current-card .footer) {
			border-top-color: rgba(255, 237, 249, 0.18);
			color: var(--c-current-work-text);
		}
	}
</style>
