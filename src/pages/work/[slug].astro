---
import { getCollection, render } from 'astro:content';
import { Picture } from 'astro:assets';
import Layout from '../../layouts/Layout.astro';
import BaseRichText from '../../components/BaseRichText.astro';
import DetailLayout from '../../components/DetailLayout.astro';
import Entry from '../../components/Entry.astro';
import EntryHeader from '../../components/EntryHeader.astro';
import EntryList from '../../components/EntryList.astro';
import type { Project } from '$lib/types/project';
import { getProjects } from '$lib/content';
import {
	getProjectImage,
	getWorkImage,
	isSvgImage,
	IMAGE_WIDTHS,
	IMAGE_FORMATS
} from '$lib/images';
import { formatDateDisplay, sortPositionsByDate, getSlug } from '$lib/util/helper';
import { renderPositionContent } from '$lib/markdown';

export async function getStaticPaths() {
	const entries = await getCollection('work');
	return entries.map((entry) => ({
		params: { slug: getSlug(entry.data.title) },
		props: { entry }
	}));
}

const { entry } = Astro.props;
const data = entry.data;
const { Content } = await render(entry);
const hasBody = (entry.body ?? '').trim().length > 0;

const sortedPositions = await Promise.all(
	sortPositionsByDate(data.positions).map(async (position) => ({
		...position,
		content: await renderPositionContent(position.content)
	}))
);

const image = data.image;
const isSvg = !!image && image !== 'TODO' && isSvgImage(image);
const workImageData = !!image && image !== 'TODO' && !isSvg ? getWorkImage(image) : null;
const hasLeadingContent = isSvg || !!workImageData;

const relatedSlugs = data.relatedProjects ?? [];
let relatedProjects: Project[] = [];
if (relatedSlugs.length > 0) {
	const projects = await getProjects();
	relatedProjects = projects.filter((p) => relatedSlugs.includes(p.slug));
}
const relatedColumns = relatedProjects.length >= 3 ? 3 : relatedProjects.length === 2 ? 2 : 1;
---

<Layout title={data.title} description={data.description} isDetailPage>
	<DetailLayout class="h-entry work-entry">
		<EntryHeader title={data.title} leadingPosition="inline">
			{
				hasLeadingContent && (
					<div slot="leading" class="icon">
						{isSvg ? (
							<img src={`/work/${image}`} alt={data.title} />
						) : (
							workImageData && (
								<Picture
									src={workImageData}
									widths={IMAGE_WIDTHS}
									formats={IMAGE_FORMATS}
									sizes="(min-width:768px) 64px, 48px"
									alt={data.title}
									loading="lazy"
									decoding="async"
								/>
							)
						)}
					</div>
				)
			}
			<Fragment slot="meta">{data.location}</Fragment>
		</EntryHeader>

		{data.description && <p class="description">{data.description}</p>}

		{
			relatedProjects.length > 0 && (
				<EntryList columns={relatedColumns} class="related-projects">
					{relatedProjects.map((project) => {
						const projectImageData = getProjectImage(project.image);
						return (
							<li>
								<Entry
									variant="gallery"
									href={project.relativePath}
									title={project.title}
									titleTag="h3"
									excerpt={project.description}
								>
									{projectImageData && (
										<Picture
											slot="media"
											src={projectImageData}
											widths={IMAGE_WIDTHS}
											formats={IMAGE_FORMATS}
											sizes="(min-width:768px) 400px, (min-width:480px) 50vw, 100vw"
											alt={project.imageAlt || project.title}
											loading="lazy"
											decoding="async"
										/>
									)}
								</Entry>
							</li>
						);
					})}
				</EntryList>
			)
		}

		{
			sortedPositions.length > 0 && (
				<div class="positions">
					{sortedPositions.map((position) => (
						<section class="position-section">
							<header class="position-header">
								<div class="position-title-group">
									<h2 class="position-title">{position.title}</h2>
									{position.employmentType && (
										<div class="employment-type">{position.employmentType}</div>
									)}
								</div>
								<div class="position-dates">
									{formatDateDisplay(position.startDate)} –{' '}
									{position.endDate ? formatDateDisplay(position.endDate) : 'Present'}
								</div>
							</header>
							<div class="position-content">
								<BaseRichText>
									<Fragment set:html={position.content} />
								</BaseRichText>
							</div>
						</section>
					))}
				</div>
			)
		}

		{
			hasBody && (
				<BaseRichText class="content">
					<Content />
				</BaseRichText>
			)
		}
	</DetailLayout>
</Layout>

<style>
	.icon {
		display: flex;
		width: 4rem;
		height: 4rem;
		flex-shrink: 0;
		flex-direction: row;
		justify-content: center;
		align-items: center;
		overflow: hidden;
		img,
		:global(picture) {
			display: block;
			margin: 0;
			padding: 0;
			width: 100%;
			height: 100%;
			border-radius: var(--border-radius-small);
			object-fit: contain;
		}
	}
	.description {
		margin: 0;
		color: var(--c-font-accent-dark);
		font-family: var(--font-family);
		font-size: var(--font-m);
		font-weight: 400;
		line-height: 1.6;
	}
	.positions {
		display: flex;
		width: 100%;
		flex-direction: column;
		gap: var(--l);
	}
	.position-section {
		display: flex;
		padding-bottom: var(--l);
		border-bottom: 1px solid var(--c-line);
		flex-direction: column;
		gap: var(--s);
		&:last-child {
			padding-bottom: 0;
			border-bottom: none;
		}
	}
	.position-header {
		display: flex;
		justify-content: space-between;
		align-items: flex-start;
		gap: var(--m);
		@media screen and (width <= 48rem) {
			flex-direction: column;
			align-items: flex-start;
			gap: var(--xs);
		}
	}
	.position-title-group {
		display: flex;
		flex: 1;
		flex-direction: column;
		align-items: flex-start;
		gap: var(--xs);
	}
	.position-title {
		margin: 0;
		color: var(--c-font);
		font-family: var(--font-family-serif);
		font-size: var(--fs-h3);
		font-weight: 500;
		letter-spacing: var(--tracking-heading);
	}
	.employment-type {
		margin: 0;
		color: var(--c-font-accent-dark);
		font-family: var(--font-family);
		font-size: var(--font-s);
		font-weight: 400;
		font-style: italic;
		line-height: 1.5;
		text-transform: capitalize;
	}
	.position-dates {
		flex-shrink: 0;
		color: var(--c-font-accent-dark);
		font-family: var(--font-family);
		font-size: var(--font-s);
		font-weight: 400;
		line-height: 1.5;
		white-space: nowrap;
	}
	.position-content {
		color: var(--c-font-accent-dark);
		font-family: var(--font-family);
		font-size: var(--font-m);
		line-height: 1.6;
	}
	.content {
		width: 100%;
		color: var(--c-font-accent-dark);
		font-family: var(--font-family);
		font-size: var(--font-m);
		line-height: 1.6;
	}
</style>
