---
import Layout from '../../layouts/Layout.astro';
import Hero from '../../components/Hero.astro';
import Entries from '../../components/Entries.astro';

const title = 'Feeds';
const description =
	'I want to expose my data in an open format that can be consumed by everyone who is interested. Either the full feed or just subsets of it.';

const feeds: Array<{ path: string; description: string }> = [
	{ path: '/rss', description: 'All content: posts, projects, uses, and work.' },
	{ path: '/work/rss', description: 'Work experience and positions.' },
	{ path: '/projects/rss', description: 'Portfolio projects.' },
	{ path: '/uses/rss', description: 'Tools and software I use.' },
	{ path: '/posts/rss', description: 'Blog posts only.' }
];
---

<Layout title={title} description={description}>
	<Entries>
		<Hero title="Feeds" description={description} />
		<div class="feeds-list">
			<ul class="list">
				{
					feeds.map(({ path, description }) => (
						<li class="item">
							<a href={path} class="path" data-astro-reload>
								{path}
							</a>
							<p class="description">{description}</p>
						</li>
					))
				}
			</ul>
		</div>
	</Entries>
</Layout>

<style>
	.feeds-list {
		display: flex;
		margin: var(--xl) auto 0;
		width: 61.8%;
		max-width: calc(var(--layout-xl) * 0.618);
		flex-direction: column;
		gap: var(--l);
		@media screen and (width <= 48rem) {
			width: 100%;
		}
		.list {
			display: flex;
			margin: 0;
			padding: 0;
			flex-direction: column;
			flex-wrap: nowrap;
			gap: var(--l);
			list-style: none;
		}
		.item {
			.path {
				color: var(--c-font);
				font-family: var(--font-family-code);
				font-size: var(--font-m);
				text-decoration: none;
				&:hover {
					text-decoration: underline;
				}
			}
			.description {
				margin: var(--s) 0 0;
				color: var(--c-font-accent-dark);
				font-family: var(--font-family);
				font-size: var(--font-s);
				line-height: 1.5;
			}
		}
	}
</style>
