---
import { getCollection, render } from 'astro:content';
import { Picture } from 'astro:assets';
import Layout from '../../layouts/Layout.astro';
import BaseCard from '../../components/BaseCard.astro';
import BaseRichText from '../../components/BaseRichText.astro';
import EntryHeader from '../../components/EntryHeader.astro';
import { Icon } from 'astro-icon/components';
import type { WorkEntry } from '$lib/types/workEntry';
import { getWork } from '$lib/content';
import { getProjectImage, IMAGE_WIDTHS, IMAGE_FORMATS } from '$lib/images';
import { getSlug } from '$lib/util/helper';

export async function getStaticPaths() {
	const entries = await getCollection('projects');
	return entries.map((entry) => ({
		params: { slug: getSlug(entry.data.title) },
		props: { entry }
	}));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const imageData = getProjectImage(entry.data.image);
const links = entry.data.links;
const relatedSlugs = entry.data.relatedWork ?? [];
let relatedWork: WorkEntry[] = [];
if (relatedSlugs.length > 0) {
	const work = await getWork();
	relatedWork = work.filter((w) => relatedSlugs.includes(w.slug));
}
---

<Layout title={entry.data.title} description={entry.data.description} isDetailPage>
	<div class:list={['project-entry', { 'with-image': !!imageData }]}>
		<EntryHeader title={entry.data.title} />
		<div class="project-body">
			{
				imageData && (
					<div class="image-block">
						<Picture
							src={imageData}
							widths={IMAGE_WIDTHS}
							formats={IMAGE_FORMATS}
							sizes="(min-width:1920px) 1280px, (min-width:1080px) 640px, (min-width:768px) 400px"
							alt={entry.data.title}
							loading="lazy"
							decoding="async"
						/>
					</div>
				)
			}
			<article class="h-entry content-column">
				<div class="content">
					<BaseRichText>
						<Content />
					</BaseRichText>
					<div class="sep" aria-hidden="true"></div>
					<nav class="links" aria-label="Project links">
						{
							links.map((link) => (
								<a href={link.url} target="_blank" rel="noopener noreferrer external">
									{link.title}
								</a>
							))
						}
					</nav>
					{
						relatedWork.length > 0 && (
							<div class="related-work">
								<h3>Related Work</h3>
								<ul class="related-work-list">
									{relatedWork.map((work) => (
										<li>
											<BaseCard
												element="a"
												href={work.relativePath}
												variant="default"
												class="withIcon"
											>
												<div class="header">
													<div class="info">
														<h4 class="name">{work.title}</h4>
													</div>
													<div class="external-link">
														<Icon name="ph:arrow-up-right-bold" />
													</div>
												</div>
											</BaseCard>
										</li>
									))}
								</ul>
							</div>
						)
					}
				</div>
			</article>
		</div>
	</div>
</Layout>

<style>
	.project-entry {
		display: flex;
		width: 100%;
		flex-direction: column;
		align-items: stretch;
		gap: var(--m);

		.project-body {
			display: grid;
			width: 100%;
			align-items: start;
			gap: var(--m);
			grid-template-columns: 0.382fr 0.618fr;
			@media screen and (width <= 48rem) {
				grid-template-columns: 1fr;
			}
			.image-block {
				min-width: 0;
				border-radius: var(--border-radius);
				overflow: hidden;
				:global(picture),
				:global(picture img) {
					display: block;
					max-width: 100%;
					height: auto;
					border-radius: var(--border-radius);
				}
			}
			.content-column {
				min-width: 0;
			}
		}

		&:not(.with-image) {
			.project-body {
				grid-template-columns: 1fr;
				.content-column {
					grid-column: 1;
				}
			}
		}
		article {
			> .content {
				display: flex;
				flex-direction: column;
				flex-wrap: nowrap;
				justify-content: flex-start;
				align-items: flex-start;
				align-content: flex-start;
				:global(.rich-text) {
					margin: 0;
				}
				.sep {
					margin: var(--l) 0;
					width: 100%;
					height: 0;
					border: none;
					border-bottom: 1px solid var(--c-surface-accent);
				}
				.links {
					display: flex;
					flex-wrap: wrap;
					gap: var(--m);
					a {
						color: var(--c-font);
						font-size: var(--font-s);
						text-decoration: none;
						&:hover {
							text-decoration: underline;
						}
					}
				}
				.related-work {
					margin-top: var(--m);
					width: 100%;
					h3 {
						margin: 0 0 var(--s) 0;
						font-family: var(--font-family);
						font-size: var(--font-m);
						font-weight: 700;
					}
					.related-work-list {
						display: flex;
						margin: 0;
						padding: 0;
						flex-direction: column;
						gap: var(--m);
						list-style: none;
						li {
							width: 100%;
						}
					}
				}
			}
		}
	}
</style>
