---
import { getCollection, render } from 'astro:content';
import { Picture } from 'astro:assets';
import Layout from '../../layouts/Layout.astro';
import BaseRichText from '../../components/BaseRichText.astro';
import DetailLayout from '../../components/DetailLayout.astro';
import Entry from '../../components/Entry.astro';
import EntryHeader from '../../components/EntryHeader.astro';
import EntryList from '../../components/EntryList.astro';
import type { WorkEntry } from '$lib/types/workEntry';
import { getWork } from '$lib/content';
import { getProjectImage, IMAGE_WIDTHS, IMAGE_FORMATS } from '$lib/images';
import { getSlug } from '$lib/util/helper';

export async function getStaticPaths() {
	const entries = await getCollection('projects');
	return entries.map((entry) => ({
		params: { slug: getSlug(entry.data.title) },
		props: { entry }
	}));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const imageData = getProjectImage(entry.data.image);
const links = entry.data.links;
const relatedSlugs = entry.data.relatedWork ?? [];
let relatedWork: WorkEntry[] = [];
if (relatedSlugs.length > 0) {
	const work = await getWork();
	relatedWork = work.filter((w) => relatedSlugs.includes(w.slug));
}
---

<Layout title={entry.data.title} description={entry.data.description} isDetailPage>
	<DetailLayout class="h-entry">
		<EntryHeader title={entry.data.title} />
		{
			imageData && (
				<div class="media">
					<Picture
						src={imageData}
						widths={IMAGE_WIDTHS}
						formats={IMAGE_FORMATS}
						sizes="(min-width:1080px) 640px, 100vw"
						alt={entry.data.imageAlt ?? entry.data.title}
						loading="lazy"
						decoding="async"
					/>
				</div>
			)
		}
		<BaseRichText class="e-content">
			<Content />
		</BaseRichText>
		{
			links.length > 0 && (
				<Fragment>
					<hr class="sep" />
					<nav class="links" aria-label="Project links">
						{links.map((link) => (
							<a href={link.url} target="_blank" rel="noopener noreferrer external">
								{link.title}
							</a>
						))}
					</nav>
				</Fragment>
			)
		}
		{
			relatedWork.length > 0 && (
				<section class="related">
					<h3>Related Work</h3>
					<EntryList>
						{relatedWork.map((work) => (
							<li>
								<Entry
									href={work.relativePath}
									title={work.title}
									titleTag="h3"
									meta={work.location}
									aria-label={`View work at ${work.title}`}
								/>
							</li>
						))}
					</EntryList>
				</section>
			)
		}
	</DetailLayout>
</Layout>

<style>
	.media {
		width: 100%;
		border-radius: var(--border-radius);
		overflow: hidden;
		:global(picture),
		:global(picture img) {
			display: block;
			width: 100%;
			max-width: 100%;
			height: auto;
			border-radius: var(--border-radius);
		}
	}
	.sep {
		margin: 0;
		width: 100%;
		height: 0;
		border: none;
		border-block-end: 1px solid var(--c-line);
	}
	.links {
		display: flex;
		flex-wrap: wrap;
		gap: var(--m);
		a {
			color: var(--c-font);
			font-size: var(--font-s);
			text-decoration: none;
			&:hover {
				text-decoration: underline;
			}
		}
	}
	.related {
		width: 100%;
		h3 {
			margin: 0 0 var(--s) 0;
			font-size: var(--font-m);
			font-weight: 700;
		}
	}
</style>
