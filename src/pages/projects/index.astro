---
import { Picture } from 'astro:assets';
import Layout from '../../layouts/Layout.astro';
import Hero from '../../components/Hero.astro';
import Entry from '../../components/Entry.astro';
import EntryList from '../../components/EntryList.astro';
import { getProjects } from '$lib/content';
import { SortDirection, SORT_DEFAULTS } from '$lib/types/enums';
import { filterAndSort } from '$lib/util/entryHelpers';
import { getProjectImage, IMAGE_WIDTHS, IMAGE_FORMATS } from '$lib/images';

const title = "Things I've built and shipped";
const description =
	"A collection of projects I've built, shipped, or contributed to over the years. Each entry is a real product or experiment, side projects, open source, client work. You'll find a mix of skills and domains I've worked in.";

const projects = await getProjects();
const filteredAndSorted = filterAndSort(
	projects,
	'all',
	'all',
	SORT_DEFAULTS.PROJECT,
	SortDirection.Desc
);

const sizes = '(min-width:1080px) 400px, (min-width:768px) 50vw, 100vw';
---

<Layout title={title} description={description}>
	<Hero slot="hero" title={title} description={description} />
	<EntryList columns={3}>
		{
			filteredAndSorted.map((entry, index) => {
				const imageData = getProjectImage(entry.image);
				return (
					<li>
						<Entry
							variant="gallery"
							featured={index === 0}
							href={entry.relativePath}
							title={entry.title}
							excerpt={entry.description}
							aria-label={`View ${entry.title}`}
						>
							{imageData && (
								<Picture
									slot="media"
									src={imageData}
									widths={IMAGE_WIDTHS}
									formats={IMAGE_FORMATS}
									sizes={sizes}
									alt={entry.imageAlt || entry.title}
									loading="lazy"
									decoding="async"
								/>
							)}
						</Entry>
					</li>
				);
			})
		}
	</EntryList>
</Layout>
