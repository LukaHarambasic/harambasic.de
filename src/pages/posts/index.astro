---
import Layout from '../../layouts/Layout.astro';
import Hero from '../../components/Hero.astro';
import Entry from '../../components/Entry.astro';
import EntryList from '../../components/EntryList.astro';
import { getPosts } from '$lib/content';
import { SortDirection, SORT_DEFAULTS } from '$lib/types/enums';
import { filterAndSort } from '$lib/util/entryHelpers';

const title = 'Writing about what I build and think';
const description =
	"A mix of technical and non-technical posts: how I build things, what I've learned, and ideas I want to put down. Everything here is something I cared enough about to write at length and publish.";

const posts = await getPosts();
const sorted = filterAndSort(posts, 'all', SORT_DEFAULTS.POST, SortDirection.Desc);
const [latest, ...rest] = sorted;
---

<Layout title={title} description={description}>
	<Hero slot="hero" title={title} description={description} />
	<div class="posts-container">
		{
			latest && (
				<Entry
					variant="card"
					featured
					href={latest.relativePath}
					title={latest.title}
					meta={latest.published.display}
					metaDatetime={latest.published.raw.toISOString()}
					excerpt={latest.description}
					class="h-feed"
					aria-label={`View post: ${latest.title}`}
				/>
			)
		}
		{
			rest.length > 0 && (
				<EntryList>
					{rest.map((post) => (
						<li class="h-feed">
							<Entry
								href={post.relativePath}
								title={post.title}
								meta={post.published.display}
								metaDatetime={post.published.raw.toISOString()}
								aria-label={`View post: ${post.title}`}
							/>
						</li>
					))}
				</EntryList>
			)
		}
	</div>
</Layout>

<style>
	.posts-container {
		display: flex;
		margin-right: auto;
		margin-left: auto;
		width: 100%;
		max-width: calc(var(--layout-xl) * 0.618);
		flex-direction: column;
		gap: var(--l);
	}
</style>
