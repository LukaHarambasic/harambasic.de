---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import BaseCallout from '../../components/BaseCallout.astro';
import BaseRichText from '../../components/BaseRichText.astro';
import DetailLayout from '../../components/DetailLayout.astro';
import EntryHeader from '../../components/EntryHeader.astro';
import TableOfContent from '../../components/TableOfContent.astro';
import { Icon } from 'astro-icon/components';
import { buildNestedToc } from '$lib/toc';
import { getSlug, formatDateDisplay } from '$lib/util/helper';
import { getPermalink } from '$lib/permalink';

export async function getStaticPaths() {
	const entries = await getCollection('posts');
	return entries.map((entry) => ({
		params: { slug: getSlug(entry.data.title) },
		props: { entry }
	}));
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);
const toc = buildNestedToc(headings);

const authorUrl = getPermalink();
const publishedIso = entry.data.published.toISOString();
const publishedDisplay = formatDateDisplay(entry.data.published);
const tldr = entry.data.tldr;
---

<Layout title={entry.data.title} description={entry.data.description} isDetailPage>
	<DetailLayout class="h-entry post-entry">
		<EntryHeader title={entry.data.title}>
			<Fragment slot="meta">
				<span class="p-author h-card">
					<a
						class="author-link"
						href={authorUrl}
						rel={authorUrl.startsWith('http') ? 'author external' : 'author'}>Luka Harambasic</a
					>
				</span>
				{
					publishedIso && (
						<>
							<span class="meta-sep" aria-hidden="true">
								{' '}
								·{' '}
							</span>
							<time class="dt-published" datetime={publishedIso}>
								{publishedDisplay}
							</time>
						</>
					)
				}
			</Fragment>
		</EntryHeader>
		<div class="sep" aria-hidden="true"></div>

		{
			tldr && (
				<>
					<div class="tldr">
						<BaseCallout prefix="TL;DR">
							<Fragment set:html={tldr} />
						</BaseCallout>
					</div>
					<div class="sep" aria-hidden="true" />
				</>
			)
		}

		{
			toc.length > 0 && (
				<>
					<details class="toc-details">
						<summary class="toc-summary">
							<span class="toc-icon">
								<Icon name="ph:caret-down-bold" />
							</span>
							<span>Table of contents</span>
						</summary>
						<div class="toc-body">
							<TableOfContent nodes={toc} />
						</div>
					</details>
					<div class="sep" aria-hidden="true" />
				</>
			)
		}

		<section class="post">
			<BaseRichText class="content e-content">
				<Content />
			</BaseRichText>
		</section>
	</DetailLayout>
	<footer class="page-footer">
		<a href="/posts/rss">RSS Feed</a>
	</footer>
</Layout>

<style>
	:global(.post-entry .entry-header .meta .author-link) {
		color: var(--c-font);
		font-style: normal;
		text-decoration: none;
	}
	.sep {
		margin: 0;
		width: 100%;
		height: 0;
		border: none;
		border-bottom: 1px solid var(--c-line);
	}
	.toc-details {
		margin: 0;
		padding: 0;
		.toc-summary {
			display: flex;
			margin: 0;
			padding: 0;
			flex-direction: row;
			flex-wrap: nowrap;
			align-items: center;
			gap: var(--s);
			color: var(--c-font);
			font-family: var(--font-family);
			font-size: var(--font-m);
			font-weight: 600;
			list-style: none;
			cursor: pointer;
			&::-webkit-details-marker {
				display: none;
			}
			&::marker {
				content: none;
			}
		}
		&[open] {
			.toc-summary {
				margin-bottom: var(--m);
			}
			.toc-icon {
				transform: rotate(180deg);
			}
		}
		.toc-icon {
			display: inline-flex;
			width: 1.25rem;
			height: 1.25rem;
			flex-shrink: 0;
			justify-content: center;
			align-items: center;
			transition: transform var(--transition);
		}
		.toc-icon :global(svg) {
			width: 1.25rem;
			height: 1.25rem;
		}
		.toc-body {
			padding: 0;
		}
	}
	.page-footer {
		margin: var(--l) 0 0 0;
		text-align: center;
		a {
			color: var(--c-font);
			font-family: var(--font-family);
			font-size: var(--font-m);
			font-weight: 600;
			text-decoration: none;
			&:hover {
				text-decoration: underline;
				text-decoration-thickness: var(--underline-thickness);
			}
		}
	}
</style>
